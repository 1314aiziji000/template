{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "V3 Evolution Memory",
  "type": "object",
  "required": [
    "id",
    "created_at",
    "title",
    "applies_to",
    "do",
    "dont",
    "evidence_links",
    "graduated_from",
    "owner_target",
    "last_verified_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "memory_kind": {
      "type": "string",
      "enum": [
        "lesson",
        "strategy"
      ]
    },
    "title": {
      "type": "string"
    },
    "applies_to": {
      "type": "string"
    },
    "do": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "dont": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "graduated_from": {
      "type": "string"
    },
    "owner_target": {
      "type": "string"
    },
    "last_verified_at": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
